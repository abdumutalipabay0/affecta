# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase — create a project at https://supabase.com
SUPABASE_URL=https://<your-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Groq — used for Whisper transcription and LLaMA-3.3-70b feedback
# https://console.groq.com
GROQ_API_KEY=gsk_<your-groq-key>

# Hume AI — optional, enables video emotion analysis
# https://beta.hume.ai
HUME_API_KEY=<your-hume-key>

# Flask session secret — set a strong random value in production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<your-secret-key>
